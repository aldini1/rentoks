# Rentoks Environment Variables
# Kopjo këtë si .env dhe plotëso vlerat

# Server
PORT=3000
NODE_ENV=development

# Database (nga Railway)
DATABASE_URL=postgresql://username:password@host:port/database

# JWT Secret (gjenero një string të gjatë random)
# Shembull: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=vendos_ketu_nje_string_sekret_shume_te_gjate_dhe_random

# App
APP_URL=http://localhost:3000
